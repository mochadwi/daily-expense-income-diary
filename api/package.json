{
  "name": "daily-expense-income-diary-api",
  "version": "0.1.0",
  "private": true,
  "description": "REST API for the Daily Expense & Income Diary (Express + TypeScript + better-sqlite3).",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
